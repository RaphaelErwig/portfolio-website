---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HomeContent from '../components/HomeContent.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    number: "01",
    category: "Hardware · CAD · FPV",
    title: "Custom High-Speed FPV Drone",
    description:
      "Design and development of a custom high-speed FPV drone, including CAD construction, additive manufacturing, component selection, soldering and complete system integration.",
    highlights: [
      "Complete CAD design",
      "Custom 3D-printed airframe",
      "6S power system",
      "Electronic system integration",
      "Thermal management",
      "Component and weight optimization",
    ],
  },
  {
    number: "02",
    category: "AI · Computer Vision · Python",
    title: "Real-Time Knife Detection",
    description:
      "A real-time computer vision system developed to detect knives in different environments using a custom dataset and YOLOv11.",
    highlights: [
      "More than 2,000 labeled images",
      "Custom dataset creation",
      "YOLOv11 and Ultralytics",
      "Training on an NVIDIA Tesla T4",
      "Real-time inference",
      "Iterative false-positive analysis",
    ],
  },
];

const strengths = [
  {
    title: "Complete Systems",
    text: "I enjoy developing complete solutions instead of focusing on only one component—from the first concept to a functional prototype.",
  },
  {
    title: "Rapid Learning",
    text: "When a project requires new skills, I independently learn the necessary tools and apply them directly to a real technical challenge.",
  },
  {
    title: "Personal Initiative",
    text: "I invest my own time and resources into ambitious engineering projects beyond university coursework.",
  },
  {
    title: "Economic Thinking",
    text: "I evaluate technical decisions not only by performance, but also by cost, efficiency, feasibility and practical value.",
  },
];

const skills = [
  "Electrical Engineering",
  "CAD Design",
  "3D Printing",
  "Hardware Integration",
  "Computer Vision",
  "YOLOv11",
  "Python",
  "Raspberry Pi",
  "ESP32",
  "Prototyping",
  "Technical Analysis",
  "Economic Evaluation",
];

const experience = [
  {
    role: "Working Student",
    company: "Renesas Electronics",
    area: "High Performance Computing",
    text: "Practical experience within the high-performance computing environment of an international semiconductor company.",
  },
  {
    role: "Internship",
    company: "Real Estate Company",
    area: "Controlling",
    text: "Experience with economic analysis, controlling processes and the evaluation of business information.",
  },
  {
    role: "Internship",
    company: "Bank",
    area: "Financial Services",
    text: "Initial professional experience in a structured financial and business environment.",
  },
];

const content = {
  nav: { about: "About", approach: "Approach", projects: "Projects", experience: "Experience", contact: "Contact" },
  hero: {
    eyebrow: "Engineering · Technology · Economic Thinking",
    title: "Building complete systems with",
    highlight: "technical precision and economic thinking.",
    intro: "I am Raphael Erwig, an Industrial Engineering student specializing in Electrical Engineering. I develop technical solutions from the first concept to a functional prototype while considering performance, feasibility, cost and practical value.",
    primary: "Explore my projects",
    secondary: "About me",
  },
  about: {
    title: "About me",
    lead: "Engineering has fascinated me since childhood. Today, I combine technical development with an interest in business, numbers and economically sound decisions.",
    paragraphs: [
      "My fascination for engineering began when I built and modified nitro-powered RC cars together with my father. Over time, this curiosity developed into the ambition to create increasingly complex hardware and software projects independently.",
      "I study Industrial Engineering with a specialization in Electrical Engineering because successful technical development requires more than engineering knowledge alone. Technical performance, costs, efficiency, feasibility and business value all influence whether an idea becomes a successful solution.",
      "I am currently in my fourth semester. I am particularly interested in hardware development, embedded systems, computer vision, additive manufacturing and the interaction between technology and economics.",
    ],
    quote: "“I do not wait for projects. I create them.”",
    quoteText: "I regularly invest my own time and resources into technical projects and independently learn the skills required to turn an idea into a working system.",
  },
  approach: { title: "How I work", lead: "My projects combine technical depth, independent learning, initiative and economic evaluation." },
  projects: { title: "Selected projects", lead: "Independent projects that combine engineering, experimentation, software, hardware and system-level problem solving." },
  experience: { title: "Experience", lead: "Experience across technology, controlling and financial services gives me insight into both engineering and business environments." },
  skills: { title: "Skills and interests", lead: "A combination of technical tools, practical engineering experience and an interest in economic decision-making." },
  contact: {
    eyebrow: "Contact",
    title: "Let us build something valuable.",
    text: "I am interested in internships, working-student positions and challenging projects at the intersection of engineering, technology and business.",
    button: "Send me an email",
  },
};
---

<BaseLayout
  lang="en"
  title="Raphael Erwig | Engineering Portfolio"
  description="Engineering portfolio of Raphael Erwig, an Industrial Engineering student specializing in Electrical Engineering."
>
  <Header lang="en" labels={content.nav} />
  <HomeContent {projects} {strengths} {skills} {experience} {content} />
  <Footer />
</BaseLayout>
