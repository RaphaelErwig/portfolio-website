---
const projects = [
  {
    number: "01",
    category: "Hardware · CAD · FPV",
    title: "Custom High-Speed FPV Drone",
    description:
      "Design and development of a custom high-speed FPV drone, including CAD construction, additive manufacturing, component selection, soldering and complete system integration.",
    highlights: [
      "Complete CAD design",
      "Custom 3D-printed airframe",
      "6S power system",
      "Electronic system integration",
      "Thermal management",
      "Component and weight optimization",
    ],
  },
  {
    number: "02",
    category: "AI · Computer Vision · Python",
    title: "Real-Time Knife Detection",
    description:
      "A real-time computer vision system developed to detect knives in different environments using a custom dataset and YOLOv11.",
    highlights: [
      "More than 2,000 labeled images",
      "Custom dataset creation",
      "YOLOv11 and Ultralytics",
      "Training on an NVIDIA Tesla T4",
      "Real-time inference",
      "Iterative false-positive analysis",
    ],
  },
];

const strengths = [
  {
    title: "Complete Systems",
    text: "I enjoy developing complete solutions instead of focusing on only one component—from the first concept to a functional prototype.",
  },
  {
    title: "Rapid Learning",
    text: "When a project requires new skills, I independently learn the necessary tools and apply them directly to a real technical challenge.",
  },
  {
    title: "Personal Initiative",
    text: "I invest my own time and resources into ambitious engineering projects beyond university coursework.",
  },
  {
    title: "Economic Thinking",
    text: "I evaluate technical decisions not only by performance, but also by cost, efficiency, feasibility and practical value.",
  },
];

const skills = [
  "Electrical Engineering",
  "CAD Design",
  "3D Printing",
  "Hardware Integration",
  "Computer Vision",
  "YOLOv11",
  "Python",
  "Raspberry Pi",
  "ESP32",
  "Prototyping",
  "Technical Analysis",
  "Economic Evaluation",
];

const experience = [
  {
    role: "Working Student",
    company: "Renesas Electronics",
    area: "High Performance Computing",
    text: "Practical experience within the high-performance computing environment of an international semiconductor company.",
  },
  {
    role: "Internship",
    company: "Real Estate Company",
    area: "Controlling",
    text: "Experience with economic analysis, controlling processes and the evaluation of business information.",
  },
  {
    role: "Internship",
    company: "Bank",
    area: "Financial Services",
    text: "Initial professional experience in a structured financial and business environment.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Engineering portfolio of Raphael Erwig, an Industrial Engineering student specializing in Electrical Engineering."
    />

    <title>Raphael Erwig | Engineering Portfolio</title>

    <style>
      :root {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;

        color: #f5f7fa;
        background: #080a0f;
        line-height: 1.6;
        font-weight: 400;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        background:
          radial-gradient(circle at 10% 5%, #172033 0, transparent 28%),
          radial-gradient(circle at 90% 15%, #15291f 0, transparent 24%),
          #080a0f;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1140px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(8, 10, 15, 0.82);
        backdrop-filter: blur(18px);
      }

      nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .logo {
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 22px;
        color: #b8c0cc;
        font-size: 0.94rem;
      }

      .nav-links a:hover {
        color: #ffffff;
      }

      .language-switch {
        display: flex;
        gap: 9px;
        padding-left: 18px;
        border-left: 1px solid rgba(255, 255, 255, 0.12);
      }

      .language-switch .active {
        color: #ffffff;
        font-weight: 700;
      }

      .hero {
        min-height: 88vh;
        display: grid;
        align-items: center;
        padding: 110px 0 90px;
      }

      .hero-content {
        max-width: 1030px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: #8dd7ac;
        font-weight: 800;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-size: 0.76rem;
      }

      h1 {
        max-width: 1000px;
        margin: 0;
        font-size: clamp(3.2rem, 7.7vw, 7rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
      }

      .highlight {
        color: #8dd7ac;
		display: block;
		margin-top: 0.08em;
      }

      .intro {
        max-width: 790px;
        margin: 30px 0 0;
        color: #b8c0cc;
        font-size: clamp(1.08rem, 2vw, 1.3rem);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 35px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 49px;
        padding: 0 23px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 999px;
        font-weight: 750;
        transition:
          transform 160ms ease,
          background 160ms ease,
          border-color 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        color: #07110b;
        background: #8dd7ac;
        border-color: #8dd7ac;
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.04);
      }

      section {
        padding: 95px 0;
      }

      .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 38px;
      }

      h2 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        line-height: 1.05;
        letter-spacing: -0.045em;
      }

      h3 {
        margin: 0;
      }

      .section-heading p {
        max-width: 560px;
        margin: 0;
        color: #9ca6b4;
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 65px;
      }

      .about-text {
        margin: 0;
        color: #b8c0cc;
        font-size: 1.14rem;
      }

      .about-text + .about-text {
        margin-top: 20px;
      }

      .quote-card {
        padding: 30px;
        border: 1px solid rgba(141, 215, 172, 0.25);
        border-radius: 24px;
        background: rgba(141, 215, 172, 0.06);
      }

      .quote-card blockquote {
        margin: 0;
        font-size: 1.55rem;
        line-height: 1.25;
        font-weight: 750;
        letter-spacing: -0.025em;
      }

      .quote-card p {
        margin: 18px 0 0;
        color: #9ca6b4;
      }

      .strength-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
      }

      .strength-card {
        padding: 28px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.035);
      }

      .strength-card h3 {
        margin-bottom: 10px;
        font-size: 1.35rem;
      }

      .strength-card p {
        margin: 0;
        color: #aeb7c4;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .project-card {
        min-height: 500px;
        display: flex;
        flex-direction: column;
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 27px;
        background:
          linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.085),
            rgba(255, 255, 255, 0.02)
          );
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .project-card:hover {
        transform: translateY(-5px);
        border-color: rgba(141, 215, 172, 0.55);
      }

      .project-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: auto;
      }

      .project-number {
        color: #8dd7ac;
        font-family: monospace;
      }

      .project-category {
        color: #7f8997;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .project-card h3 {
        margin-top: 90px;
        font-size: 2rem;
        letter-spacing: -0.035em;
      }

      .project-card > p {
        margin: 14px 0 0;
        color: #aeb7c4;
      }

      .highlight-list {
        display: grid;
        gap: 9px;
        margin: 24px 0 0;
        padding: 0;
        list-style: none;
      }

      .highlight-list li {
        position: relative;
        padding-left: 18px;
        color: #d0d6df;
        font-size: 0.92rem;
      }

      .highlight-list li::before {
        content: "";
        position: absolute;
        top: 0.68em;
        left: 0;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #8dd7ac;
      }

      .experience-list {
        display: grid;
        gap: 18px;
      }

      .experience-card {
        display: grid;
        grid-template-columns: 0.8fr 1fr 1.6fr;
        gap: 25px;
        padding: 25px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.09);
      }

      .experience-role {
        font-weight: 750;
      }

      .experience-company {
        color: #8dd7ac;
      }

      .experience-description {
        margin: 0;
        color: #aeb7c4;
      }

      .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .skill {
        padding: 10px 15px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
      }

      .contact {
        text-align: center;
        padding-bottom: 125px;
      }

      .contact p {
        max-width: 680px;
        margin: 18px auto 28px;
        color: #aeb7c4;
      }

      footer {
        padding: 28px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        color: #7f8997;
        font-size: 0.9rem;
      }

      @media (max-width: 820px) {
        .about-grid,
        .project-grid,
        .strength-grid {
          grid-template-columns: 1fr;
        }

        .experience-card {
          grid-template-columns: 1fr;
          gap: 7px;
        }

        .section-heading {
          display: block;
        }

        .section-heading p {
          margin-top: 15px;
        }
      }

      @media (max-width: 680px) {
        .nav-links > a {
          display: none;
        }

        .language-switch a {
          display: inline;
        }

        .hero {
          min-height: auto;
          padding-top: 90px;
        }

        .project-card {
          min-height: auto;
        }

        .project-card h3 {
          margin-top: 70px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav class="container">
        <a class="logo" href="/">Raphael Erwig</a>

        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#approach">Approach</a>
          <a href="#projects">Projects</a>
          <a href="#experience">Experience</a>
          <a href="#contact">Contact</a>

          <div class="language-switch">
            <a class="active" href="/">EN</a>
            <a href="/de/">DE</a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero container">
        <div class="hero-content">
          <p class="eyebrow">
            Engineering · Technology · Economic Thinking
          </p>

          <h1>
            Building complete systems with
            <span class="highlight">
              technical precision and economic thinking.
            </span>
          </h1>

          <p class="intro">
            I am Raphael Erwig, an Industrial Engineering student specializing
            in Electrical Engineering. I develop technical solutions from the
            first concept to a functional prototype while considering
            performance, feasibility, cost and practical value.
          </p>

          <div class="buttons">
            <a class="button button-primary" href="#projects">
              Explore my projects
            </a>

            <a class="button button-secondary" href="#about">
              About me
            </a>
          </div>
        </div>
      </section>

      <section id="about" class="container">
        <div class="section-heading">
          <h2>About me</h2>

          <p>
            Engineering has fascinated me since childhood. Today, I combine
            technical development with an interest in business, numbers and
            economically sound decisions.
          </p>
        </div>

        <div class="about-grid">
          <div>
            <p class="about-text">
              My fascination for engineering began when I built and modified
              nitro-powered RC cars together with my father. Over time, this
              curiosity developed into the ambition to create increasingly
              complex hardware and software projects independently.
            </p>

            <p class="about-text">
              I study Industrial Engineering with a specialization in
              Electrical Engineering because successful technical development
              requires more than engineering knowledge alone. Technical
              performance, costs, efficiency, feasibility and business value
              all influence whether an idea becomes a successful solution.
            </p>

            <p class="about-text">
              I am currently in my fourth semester. I am particularly
              interested in hardware development, embedded systems, computer
              vision, additive manufacturing and the interaction between
              technology and economics.
            </p>
          </div>

          <aside class="quote-card">
            <blockquote>
              “I do not wait for projects. I create them.”
            </blockquote>

            <p>
              I regularly invest my own time and resources into technical
              projects and independently learn the skills required to turn an
              idea into a working system.
            </p>
          </aside>
        </div>
      </section>

      <section id="approach" class="container">
        <div class="section-heading">
          <h2>How I work</h2>

          <p>
            My projects combine technical depth, independent learning,
            initiative and economic evaluation.
          </p>
        </div>

        <div class="strength-grid">
          {
            strengths.map((strength) => (
              <article class="strength-card">
                <h3>{strength.title}</h3>
                <p>{strength.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="projects" class="container">
        <div class="section-heading">
          <h2>Selected projects</h2>

          <p>
            Independent projects that combine engineering, experimentation,
            software, hardware and system-level problem solving.
          </p>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class="project-top">
                  <span class="project-number">{project.number}</span>
                  <span class="project-category">{project.category}</span>
                </div>

                <h3>{project.title}</h3>
                <p>{project.description}</p>

                <ul class="highlight-list">
                  {
                    project.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))
                  }
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section id="experience" class="container">
        <div class="section-heading">
          <h2>Experience</h2>

          <p>
            Experience across technology, controlling and financial services
            gives me insight into both engineering and business environments.
          </p>
        </div>

        <div class="experience-list">
          {
            experience.map((item) => (
              <article class="experience-card">
                <div>
                  <div class="experience-role">{item.role}</div>
                  <div>{item.area}</div>
                </div>

                <div class="experience-company">{item.company}</div>

                <p class="experience-description">{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="container">
        <div class="section-heading">
          <h2>Skills and interests</h2>

          <p>
            A combination of technical tools, practical engineering experience
            and an interest in economic decision-making.
          </p>
        </div>

        <div class="skills">
          {skills.map((skill) => <span class="skill">{skill}</span>)}
        </div>
      </section>

      <section id="contact" class="contact container">
        <p class="eyebrow">Contact</p>

        <h2>Let us build something valuable.</h2>

        <p>
          I am interested in internships, working-student positions and
          challenging projects at the intersection of engineering, technology
          and business.
        </p>

        <a
          class="button button-primary"
          href="mailto:Raphael.Erwig@icloud.com"
        >
          Send me an email
        </a>
      </section>
    </main>

    <footer>
      <div class="container">
        © {new Date().getFullYear()} Raphael Erwig
      </div>
    </footer>
  </body>
</html>