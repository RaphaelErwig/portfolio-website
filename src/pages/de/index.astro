---
const projects = [
  {
    number: "01",
    category: "Hardware · CAD · FPV",
    title: "Eigene High-Speed-FPV-Drohne",
    description:
      "Konstruktion und Entwicklung einer eigenen High-Speed-FPV-Drohne – von der CAD-Konstruktion und additiven Fertigung bis zur Komponentenauswahl, Verkabelung und vollständigen Systemintegration.",
    highlights: [
      "Vollständige CAD-Konstruktion",
      "Eigener 3D-gedruckter Flugkörper",
      "6S-Antriebssystem",
      "Integration der Elektronik",
      "Wärmemanagement",
      "Optimierung von Komponenten und Gewicht",
    ],
  },
  {
    number: "02",
    category: "KI · Computer Vision · Python",
    title: "Echtzeit-Messererkennung",
    description:
      "Entwicklung eines echtzeitfähigen Computer-Vision-Systems zur Erkennung von Messern in unterschiedlichen Umgebungen mit einem eigenen Datensatz und YOLOv11.",
    highlights: [
      "Mehr als 2.000 gelabelte Bilder",
      "Aufbau eines eigenen Datensatzes",
      "YOLOv11 und Ultralytics",
      "Training auf einer NVIDIA Tesla T4",
      "Echtzeit-Inferenz",
      "Iterative Analyse von False Positives",
    ],
  },
];

const strengths = [
  {
    title: "Komplette Systeme",
    text: "Ich entwickle gerne vollständige Lösungen, statt mich nur auf eine einzelne Komponente zu konzentrieren – von der ersten Idee bis zum funktionsfähigen Prototyp.",
  },
  {
    title: "Schnelles Lernen",
    text: "Erfordert ein Projekt neue Fähigkeiten, eigne ich mir die notwendigen Werkzeuge selbstständig an und wende sie direkt auf eine reale technische Herausforderung an.",
  },
  {
    title: "Hohe Eigeninitiative",
    text: "Ich investiere eigene Zeit und Ressourcen in anspruchsvolle technische Projekte, die über die Inhalte meines Studiums hinausgehen.",
  },
  {
    title: "Wirtschaftliches Denken",
    text: "Ich bewerte technische Entscheidungen nicht nur nach ihrer Leistung, sondern auch anhand von Kosten, Effizienz, Machbarkeit und praktischem Nutzen.",
  },
];

const skills = [
  "Elektrotechnik",
  "CAD-Konstruktion",
  "3D-Druck",
  "Hardware-Integration",
  "Computer Vision",
  "YOLOv11",
  "Python",
  "Raspberry Pi",
  "ESP32",
  "Prototyping",
  "Technische Analyse",
  "Wirtschaftliche Bewertung",
];

const experience = [
  {
    role: "Werkstudent",
    company: "Renesas Electronics",
    area: "High Performance Computing",
    text: "Praktische Erfahrung im High-Performance-Computing-Umfeld eines internationalen Halbleiterunternehmens.",
  },
  {
    role: "Praktikum",
    company: "Immobilienunternehmen",
    area: "Controlling",
    text: "Erfahrung mit wirtschaftlichen Analysen, Controlling-Prozessen und der Bewertung betrieblicher Informationen.",
  },
  {
    role: "Praktikum",
    company: "Bank",
    area: "Finanzdienstleistungen",
    text: "Erste berufliche Erfahrungen in einem strukturierten finanzwirtschaftlichen und unternehmerischen Umfeld.",
  },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Engineering-Portfolio von Raphael Erwig, Student des Wirtschaftsingenieurwesens mit Schwerpunkt Elektrotechnik."
    />

    <title>Raphael Erwig | Engineering-Portfolio</title>

    <style>
      :root {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;

        color: #f5f7fa;
        background: #080a0f;
        line-height: 1.6;
        font-weight: 400;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        background:
          radial-gradient(circle at 10% 5%, #172033 0, transparent 28%),
          radial-gradient(circle at 90% 15%, #15291f 0, transparent 24%),
          #080a0f;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1140px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(8, 10, 15, 0.82);
        backdrop-filter: blur(18px);
      }

      nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .logo {
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 22px;
        color: #b8c0cc;
        font-size: 0.94rem;
      }

      .nav-links a:hover {
        color: #ffffff;
      }

      .language-switch {
        display: flex;
        gap: 9px;
        padding-left: 18px;
        border-left: 1px solid rgba(255, 255, 255, 0.12);
      }

      .language-switch .active {
        color: #ffffff;
        font-weight: 700;
      }

      .hero {
        min-height: 88vh;
        display: grid;
        align-items: center;
        padding: 110px 0 90px;
      }

      .hero-content {
        max-width: 1030px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: #8dd7ac;
        font-weight: 800;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        font-size: 0.76rem;
      }

      h1 {
        max-width: 1000px;
        margin: 0;
        font-size: clamp(3.2rem, 7.7vw, 7rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
      }

      .highlight {
        color: #8dd7ac;
      }

      .intro {
        max-width: 790px;
        margin: 30px 0 0;
        color: #b8c0cc;
        font-size: clamp(1.08rem, 2vw, 1.3rem);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 35px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 49px;
        padding: 0 23px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 999px;
        font-weight: 750;
        transition:
          transform 160ms ease,
          background 160ms ease,
          border-color 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        color: #07110b;
        background: #8dd7ac;
        border-color: #8dd7ac;
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.04);
      }

      section {
        padding: 95px 0;
      }

      .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 38px;
      }

      h2 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        line-height: 1.05;
        letter-spacing: -0.045em;
      }

      h3 {
        margin: 0;
      }

      .section-heading p {
        max-width: 560px;
        margin: 0;
        color: #9ca6b4;
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 65px;
      }

      .about-text {
        margin: 0;
        color: #b8c0cc;
        font-size: 1.14rem;
      }

      .about-text + .about-text {
        margin-top: 20px;
      }

      .quote-card {
        padding: 30px;
        border: 1px solid rgba(141, 215, 172, 0.25);
        border-radius: 24px;
        background: rgba(141, 215, 172, 0.06);
      }

      .quote-card blockquote {
        margin: 0;
        font-size: 1.55rem;
        line-height: 1.25;
        font-weight: 750;
        letter-spacing: -0.025em;
      }

      .quote-card p {
        margin: 18px 0 0;
        color: #9ca6b4;
      }

      .strength-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
      }

      .strength-card {
        padding: 28px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.035);
      }

      .strength-card h3 {
        margin-bottom: 10px;
        font-size: 1.35rem;
      }

      .strength-card p {
        margin: 0;
        color: #aeb7c4;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .project-card {
        min-height: 500px;
        display: flex;
        flex-direction: column;
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 27px;
        background:
          linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.085),
            rgba(255, 255, 255, 0.02)
          );
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .project-card:hover {
        transform: translateY(-5px);
        border-color: rgba(141, 215, 172, 0.55);
      }

      .project-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: auto;
      }

      .project-number {
        color: #8dd7ac;
        font-family: monospace;
      }

      .project-category {
        color: #7f8997;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .project-card h3 {
        margin-top: 90px;
        font-size: 2rem;
        letter-spacing: -0.035em;
      }

      .project-card > p {
        margin: 14px 0 0;
        color: #aeb7c4;
      }

      .highlight-list {
        display: grid;
        gap: 9px;
        margin: 24px 0 0;
        padding: 0;
        list-style: none;
      }

      .highlight-list li {
        position: relative;
        padding-left: 18px;
        color: #d0d6df;
        font-size: 0.92rem;
      }

      .highlight-list li::before {
        content: "";
        position: absolute;
        top: 0.68em;
        left: 0;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #8dd7ac;
      }

      .experience-list {
        display: grid;
        gap: 18px;
      }

      .experience-card {
        display: grid;
        grid-template-columns: 0.8fr 1fr 1.6fr;
        gap: 25px;
        padding: 25px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.09);
      }

      .experience-role {
        font-weight: 750;
      }

      .experience-company {
        color: #8dd7ac;
      }

      .experience-description {
        margin: 0;
        color: #aeb7c4;
      }

      .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .skill {
        padding: 10px 15px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
      }

      .contact {
        text-align: center;
        padding-bottom: 125px;
      }

      .contact p {
        max-width: 680px;
        margin: 18px auto 28px;
        color: #aeb7c4;
      }

      footer {
        padding: 28px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        color: #7f8997;
        font-size: 0.9rem;
      }

      @media (max-width: 820px) {
        .about-grid,
        .project-grid,
        .strength-grid {
          grid-template-columns: 1fr;
        }

        .experience-card {
          grid-template-columns: 1fr;
          gap: 7px;
        }

        .section-heading {
          display: block;
        }

        .section-heading p {
          margin-top: 15px;
        }
      }

      @media (max-width: 680px) {
        .nav-links > a {
          display: none;
        }

        .language-switch a {
          display: inline;
        }

        .hero {
          min-height: auto;
          padding-top: 90px;
        }

        .project-card {
          min-height: auto;
        }

        .project-card h3 {
          margin-top: 70px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav class="container">
        <a class="logo" href="/de/">Raphael Erwig</a>

        <div class="nav-links">
          <a href="#about">Über mich</a>
          <a href="#approach">Arbeitsweise</a>
          <a href="#projects">Projekte</a>
          <a href="#experience">Erfahrung</a>
          <a href="#contact">Kontakt</a>

          <div class="language-switch">
            <a href="/">EN</a>
            <a class="active" href="/de/">DE</a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero container">
        <div class="hero-content">
          <p class="eyebrow">
            Engineering · Technologie · Wirtschaftliches Denken
          </p>

          <h1>
            Entwicklung kompletter Systeme mit
            <span class="highlight">
              technischer Präzision und wirtschaftlichem Denken.
            </span>
          </h1>

          <p class="intro">
            Ich bin Raphael Erwig und studiere Wirtschaftsingenieurwesen mit
            Schwerpunkt Elektrotechnik. Ich entwickle technische Lösungen von
            der ersten Idee bis zum funktionsfähigen Prototyp und berücksichtige
            dabei Leistung, Machbarkeit, Kosten und praktischen Nutzen.
          </p>

          <div class="buttons">
            <a class="button button-primary" href="#projects">
              Meine Projekte
            </a>

            <a class="button button-secondary" href="#about">
              Über mich
            </a>
          </div>
        </div>
      </section>

      <section id="about" class="container">
        <div class="section-heading">
          <h2>Über mich</h2>

          <p>
            Technik fasziniert mich seit meiner Kindheit. Heute verbinde ich
            technische Entwicklung mit meinem Interesse an Wirtschaft, Zahlen
            und fundierten unternehmerischen Entscheidungen.
          </p>
        </div>

        <div class="about-grid">
          <div>
            <p class="about-text">
              Meine Begeisterung für Technik begann, als ich gemeinsam mit
              meinem Vater Verbrenner-RC-Autos aufgebaut und verändert habe.
              Aus dieser Neugier entwickelte sich mit der Zeit der Anspruch,
              immer komplexere Hard- und Softwareprojekte selbstständig
              umzusetzen.
            </p>

            <p class="about-text">
              Ich studiere Wirtschaftsingenieurwesen mit Schwerpunkt
              Elektrotechnik, weil erfolgreiche technische Entwicklung mehr als
              reines Ingenieurwissen erfordert. Technische Leistung, Kosten,
              Effizienz, Machbarkeit und wirtschaftlicher Nutzen entscheiden
              gemeinsam darüber, ob aus einer Idee eine erfolgreiche Lösung
              wird.
            </p>

            <p class="about-text">
              Aktuell befinde ich mich im vierten Semester. Besonders
              interessieren mich Hardwareentwicklung, Embedded Systems,
              Computer Vision, additive Fertigung und die Verbindung von
              Technik und Wirtschaft.
            </p>
          </div>

          <aside class="quote-card">
            <blockquote>
              „Ich warte nicht auf Projekte. Ich schaffe sie selbst.“
            </blockquote>

            <p>
              Ich investiere regelmäßig eigene Zeit und Ressourcen in
              technische Projekte und eigne mir selbstständig die Fähigkeiten
              an, die notwendig sind, um eine Idee in ein funktionierendes
              System zu verwandeln.
            </p>
          </aside>
        </div>
      </section>

      <section id="approach" class="container">
        <div class="section-heading">
          <h2>Meine Arbeitsweise</h2>

          <p>
            Meine Projekte verbinden technisches Verständnis, selbstständiges
            Lernen, Eigeninitiative und wirtschaftliche Bewertung.
          </p>
        </div>

        <div class="strength-grid">
          {
            strengths.map((strength) => (
              <article class="strength-card">
                <h3>{strength.title}</h3>
                <p>{strength.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="projects" class="container">
        <div class="section-heading">
          <h2>Ausgewählte Projekte</h2>

          <p>
            Eigenständige Projekte, die Engineering, Experimentieren,
            Software, Hardware und systemisches Problemlösen miteinander
            verbinden.
          </p>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <div class="project-top">
                  <span class="project-number">{project.number}</span>
                  <span class="project-category">{project.category}</span>
                </div>

                <h3>{project.title}</h3>
                <p>{project.description}</p>

                <ul class="highlight-list">
                  {
                    project.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))
                  }
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section id="experience" class="container">
        <div class="section-heading">
          <h2>Berufliche Erfahrung</h2>

          <p>
            Erfahrungen aus Technologie, Controlling und Finanzwirtschaft geben
            mir Einblicke in technische und wirtschaftliche Arbeitsumfelder.
          </p>
        </div>

        <div class="experience-list">
          {
            experience.map((item) => (
              <article class="experience-card">
                <div>
                  <div class="experience-role">{item.role}</div>
                  <div>{item.area}</div>
                </div>

                <div class="experience-company">{item.company}</div>

                <p class="experience-description">{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="container">
        <div class="section-heading">
          <h2>Fähigkeiten und Interessen</h2>

          <p>
            Eine Kombination aus technischen Werkzeugen, praktischer
            Engineering-Erfahrung und Interesse an wirtschaftlicher
            Entscheidungsfindung.
          </p>
        </div>

        <div class="skills">
          {skills.map((skill) => <span class="skill">{skill}</span>)}
        </div>
      </section>

      <section id="contact" class="contact container">
        <p class="eyebrow">Kontakt</p>

        <h2>Lassen Sie uns etwas Wertvolles entwickeln.</h2>

        <p>
          Ich interessiere mich für Praktika, Werkstudentenstellen und
          anspruchsvolle Projekte an der Schnittstelle zwischen Engineering,
          Technologie und Wirtschaft.
        </p>

        <a
          class="button button-primary"
          href="mailto:Raphael.Erwig@icloud.com"
        >
          E-Mail senden
        </a>
      </section>
    </main>

    <footer>
      <div class="container">
        © {new Date().getFullYear()} Raphael Erwig
      </div>
    </footer>
  </body>
</html>