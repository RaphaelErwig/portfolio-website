---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import HomeContent from '../../components/HomeContent.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    number: "01",
    category: "Hardware · CAD · FPV",
    title: "Eigene High-Speed-FPV-Drohne",
    description:
      "Konstruktion und Entwicklung einer eigenen High-Speed-FPV-Drohne – von der CAD-Konstruktion und additiven Fertigung bis zur Komponentenauswahl, Verkabelung und vollständigen Systemintegration.",
    highlights: [
      "Vollständige CAD-Konstruktion",
      "Eigener 3D-gedruckter Flugkörper",
      "6S-Antriebssystem",
      "Integration der Elektronik",
      "Wärmemanagement",
      "Optimierung von Komponenten und Gewicht",
    ],
  },
  {
    number: "02",
    category: "KI · Computer Vision · Python",
    title: "Echtzeit-Messererkennung",
    description:
      "Entwicklung eines echtzeitfähigen Computer-Vision-Systems zur Erkennung von Messern in unterschiedlichen Umgebungen mit einem eigenen Datensatz und YOLOv11.",
    highlights: [
      "Mehr als 2.000 gelabelte Bilder",
      "Aufbau eines eigenen Datensatzes",
      "YOLOv11 und Ultralytics",
      "Training auf einer NVIDIA Tesla T4",
      "Echtzeit-Inferenz",
      "Iterative Analyse von False Positives",
    ],
  },
];

const strengths = [
  {
    title: "Komplette Systeme",
    text: "Ich entwickle gerne vollständige Lösungen, statt mich nur auf eine einzelne Komponente zu konzentrieren – von der ersten Idee bis zum funktionsfähigen Prototyp.",
  },
  {
    title: "Schnelles Lernen",
    text: "Erfordert ein Projekt neue Fähigkeiten, eigne ich mir die notwendigen Werkzeuge selbstständig an und wende sie direkt auf eine reale technische Herausforderung an.",
  },
  {
    title: "Hohe Eigeninitiative",
    text: "Ich investiere eigene Zeit und Ressourcen in anspruchsvolle technische Projekte, die über die Inhalte meines Studiums hinausgehen.",
  },
  {
    title: "Wirtschaftliches Denken",
    text: "Ich bewerte technische Entscheidungen nicht nur nach ihrer Leistung, sondern auch anhand von Kosten, Effizienz, Machbarkeit und praktischem Nutzen.",
  },
];

const skills = [
  "Elektrotechnik",
  "CAD-Konstruktion",
  "3D-Druck",
  "Hardware-Integration",
  "Computer Vision",
  "YOLOv11",
  "Python",
  "Raspberry Pi",
  "ESP32",
  "Prototyping",
  "Technische Analyse",
  "Wirtschaftliche Bewertung",
];

const experience = [
  {
    role: "Werkstudent",
    company: "Renesas Electronics",
    area: "High Performance Computing",
    text: "Praktische Erfahrung im High-Performance-Computing-Umfeld eines internationalen Halbleiterunternehmens.",
  },
  {
    role: "Praktikum",
    company: "Immobilienunternehmen",
    area: "Controlling",
    text: "Erfahrung mit wirtschaftlichen Analysen, Controlling-Prozessen und der Bewertung betrieblicher Informationen.",
  },
  {
    role: "Praktikum",
    company: "Bank",
    area: "Finanzdienstleistungen",
    text: "Erste berufliche Erfahrungen in einem strukturierten finanzwirtschaftlichen und unternehmerischen Umfeld.",
  },
];

const content = {
  nav: { about: "Über mich", approach: "Arbeitsweise", projects: "Projekte", experience: "Erfahrung", contact: "Kontakt" },
  hero: {
    eyebrow: "Engineering · Technologie · Wirtschaftliches Denken",
    title: "Entwicklung kompletter Systeme mit",
    highlight: "technischer Präzision und wirtschaftlichem Denken.",
    intro: "Ich bin Raphael Erwig und studiere Wirtschaftsingenieurwesen mit Schwerpunkt Elektrotechnik. Ich entwickle technische Lösungen von der ersten Idee bis zum funktionsfähigen Prototyp und berücksichtige dabei Leistung, Machbarkeit, Kosten und praktischen Nutzen.",
    primary: "Meine Projekte",
    secondary: "Über mich",
  },
  about: {
    title: "Über mich",
    lead: "Technik fasziniert mich seit meiner Kindheit. Heute verbinde ich technische Entwicklung mit meinem Interesse an Wirtschaft, Zahlen und fundierten unternehmerischen Entscheidungen.",
    paragraphs: [
      "Meine Begeisterung für Technik begann, als ich gemeinsam mit meinem Vater Verbrenner-RC-Autos aufgebaut und modifiziert habe. Aus dieser Neugier entwickelte sich mit der Zeit der Anspruch, immer komplexere Hard- und Softwareprojekte selbstständig umzusetzen.",
      "Ich studiere Wirtschaftsingenieurwesen mit Schwerpunkt Elektrotechnik, weil erfolgreiche technische Entwicklung mehr als reines Ingenieurwissen erfordert. Technische Leistung, Kosten, Effizienz, Machbarkeit und wirtschaftlicher Nutzen entscheiden gemeinsam darüber, ob aus einer Idee eine erfolgreiche Lösung wird.",
      "Aktuell befinde ich mich im vierten Semester. Besonders interessieren mich Hardwareentwicklung, Embedded Systems, Computer Vision, additive Fertigung und die Verbindung von Technik und Wirtschaft.",
    ],
    quote: "„Ich warte nicht auf Projekte. Ich schaffe sie selbst.“",
    quoteText: "Ich investiere regelmäßig eigene Zeit und Ressourcen in technische Projekte und eigne mir selbstständig die Fähigkeiten an, die notwendig sind, um eine Idee in ein funktionierendes System zu verwandeln.",
  },
  approach: { title: "Meine Arbeitsweise", lead: "Meine Projekte verbinden technisches Verständnis, selbstständiges Lernen, Eigeninitiative und wirtschaftliche Bewertung." },
  projects: { title: "Ausgewählte Projekte", lead: "Eigenständige Projekte, die Engineering, Experimentieren, Software, Hardware und systemisches Problemlösen miteinander verbinden." },
  experience: { title: "Berufliche Erfahrung", lead: "Erfahrungen aus Technologie, Controlling und Finanzwirtschaft geben mir Einblicke in technische und wirtschaftliche Arbeitsumfelder." },
  skills: { title: "Fähigkeiten und Interessen", lead: "Eine Kombination aus technischen Werkzeugen, praktischer Engineering-Erfahrung und Interesse an wirtschaftlicher Entscheidungsfindung." },
  contact: {
    eyebrow: "Kontakt",
    title: "Lassen Sie uns etwas Wertvolles entwickeln.",
    text: "Ich interessiere mich für Praktika, Werkstudentenstellen und anspruchsvolle Projekte an der Schnittstelle zwischen Engineering, Technologie und Wirtschaft.",
    button: "E-Mail senden",
  },
};
---

<BaseLayout
  lang="de"
  title="Raphael Erwig | Engineering Portfolio"
  description="Engineering-Portfolio von Raphael Erwig, Student des Wirtschaftsingenieurwesens mit Schwerpunkt Elektrotechnik."
>
  <Header lang="de" labels={content.nav} />
  <HomeContent {projects} {strengths} {skills} {experience} {content} />
  <Footer />
</BaseLayout>
