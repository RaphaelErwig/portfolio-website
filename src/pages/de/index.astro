---
const projects = [
  {
    title: "High-Speed-Drohne",
    description:
      "Entwicklung und Bau einer eigenen High-Speed-FPV-Drohne mit Fokus auf Leistung, Gewicht, Aerodynamik und zuverlässige Elektronik.",
    tags: ["Elektronik", "CAD", "FPV", "Prototyping"],
  },
  {
    title: "KI-Messererkennung",
    description:
      "Ein Computer-Vision-System zur Erkennung von Messern in Bildern und Videostreams mithilfe von Machine Learning und Objekterkennung.",
    tags: ["Python", "Computer Vision", "KI", "Objekterkennung"],
  },
];

const skills = [
  "Elektrotechnik",
  "Python",
  "C / C++",
  "Embedded Systems",
  "Computer Vision",
  "Machine Learning",
  "CAD",
  "Prototyping",
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Engineering-Portfolio von Raphael Erwig, Student des Wirtschaftsingenieurwesens mit Schwerpunkt Elektrotechnik."
    />

    <title>Raphael Erwig | Engineering-Portfolio</title>

    <style>
      :root {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;

        color: #f5f7fa;
        background: #090b10;
        line-height: 1.6;
        font-weight: 400;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        background:
          radial-gradient(circle at 15% 10%, #172033 0, transparent 30%),
          radial-gradient(circle at 85% 20%, #15291f 0, transparent 25%),
          #090b10;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 10;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(9, 11, 16, 0.82);
        backdrop-filter: blur(16px);
      }

      nav {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .logo {
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 22px;
        color: #b8c0cc;
        font-size: 0.95rem;
      }

      .nav-links a:hover {
        color: white;
      }

      .language-switch {
        display: flex;
        gap: 8px;
        padding-left: 18px;
        border-left: 1px solid rgba(255, 255, 255, 0.12);
      }

      .language-switch .active {
        color: white;
        font-weight: 700;
      }

      .hero {
        min-height: 82vh;
        display: grid;
        align-items: center;
        padding: 100px 0 80px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: #8dd7ac;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: 0.78rem;
      }

      h1 {
        max-width: 920px;
        margin: 0;
        font-size: clamp(3rem, 8vw, 7rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
      }

      .highlight {
        color: #8dd7ac;
      }

      .intro {
        max-width: 720px;
        margin: 30px 0 0;
        color: #b8c0cc;
        font-size: clamp(1.05rem, 2vw, 1.3rem);
      }

      .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        font-weight: 700;
        transition:
          transform 160ms ease,
          background 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        color: #07110b;
        background: #8dd7ac;
        border-color: #8dd7ac;
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.04);
      }

      section {
        padding: 90px 0;
      }

      .section-heading {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 30px;
        margin-bottom: 34px;
      }

      h2 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 3.5rem);
        letter-spacing: -0.04em;
      }

      .section-heading p {
        max-width: 540px;
        margin: 0;
        color: #9ca6b4;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .card {
        min-height: 330px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 30px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 26px;
        background:
          linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.09),
            rgba(255, 255, 255, 0.025)
          );
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .card:hover {
        transform: translateY(-5px);
        border-color: rgba(141, 215, 172, 0.55);
      }

      .card-number {
        margin-bottom: auto;
        color: #8dd7ac;
        font-family: monospace;
      }

      .card h3 {
        margin: 0 0 12px;
        font-size: 1.8rem;
      }

      .card p {
        margin: 0;
        color: #aeb7c4;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 22px;
      }

      .tag {
        padding: 6px 11px;
        border: 1px solid rgba(255, 255, 255, 0.11);
        border-radius: 999px;
        color: #c9d0da;
        font-size: 0.82rem;
      }

      .about-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 60px;
      }

      .about-text {
        margin: 0;
        color: #b8c0cc;
        font-size: 1.15rem;
      }

      .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-content: start;
      }

      .skill {
        padding: 10px 15px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .contact {
        text-align: center;
        padding-bottom: 120px;
      }

      .contact p {
        max-width: 620px;
        margin: 18px auto 28px;
        color: #aeb7c4;
      }

      footer {
        padding: 28px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        color: #7f8997;
        font-size: 0.9rem;
      }

      @media (max-width: 760px) {
        .nav-links > a:not(.language-switch a) {
          display: none;
        }

        .project-grid,
        .about-grid {
          grid-template-columns: 1fr;
        }

        .section-heading {
          display: block;
        }

        .section-heading p {
          margin-top: 14px;
        }

        .hero {
          min-height: auto;
          padding-top: 90px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav class="container">
        <a class="logo" href="/de/">Raphael Erwig</a>

        <div class="nav-links">
          <a href="#projects">Projekte</a>
          <a href="#about">Über mich</a>
          <a href="#contact">Kontakt</a>

          <div class="language-switch">
            <a href="/">EN</a>
            <a class="active" href="/de/">DE</a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero container">
        <div>
          <p class="eyebrow">
            Engineering · Embedded Systems · Computer Vision
          </p>

          <h1>
            Ich verwandle technische Ideen in
            <span class="highlight">funktionierende Systeme.</span>
          </h1>

          <p class="intro">
            Ich bin Raphael Erwig und studiere Wirtschaftsingenieurwesen mit
            Schwerpunkt Elektrotechnik. Ich entwickle Hardware- und
            Softwareprojekte von High-Speed-Drohnen bis zur KI-basierten
            Objekterkennung.
          </p>

          <div class="buttons">
            <a class="button button-primary" href="#projects">
              Meine Projekte
            </a>

            <a class="button button-secondary" href="#contact">
              Kontakt aufnehmen
            </a>
          </div>
        </div>
      </section>

      <section id="projects" class="container">
        <div class="section-heading">
          <h2>Ausgewählte Projekte</h2>

          <p>
            Eigene Engineering-Projekte, die Elektronik, Software,
            mechanische Konstruktion und praktische Erprobung verbinden.
          </p>
        </div>

        <div class="project-grid">
          {
            projects.map((project, index) => (
              <article class="card">
                <span class="card-number">
                  0{index + 1}
                </span>

                <h3>{project.title}</h3>
                <p>{project.description}</p>

                <div class="tags">
                  {project.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="about" class="container">
        <div class="section-heading">
          <h2>Über mich</h2>
        </div>

        <div class="about-grid">
          <p class="about-text">
            Ich entwickle technische Systeme gerne vom ersten Konzept bis zum
            funktionsfähigen Prototyp. Meine Interessen liegen insbesondere in
            den Bereichen Embedded Systems, Elektrotechnik, Computer Vision,
            autonome Systeme und technisch anspruchsvolle Prototypen.
          </p>

          <div class="skills">
            {skills.map((skill) => <span class="skill">{skill}</span>)}
          </div>
        </div>
      </section>

      <section id="contact" class="contact container">
        <p class="eyebrow">Kontakt</p>
        <h2>Lassen Sie uns etwas Interessantes entwickeln.</h2>

        <p>
          Ich bin offen für Praktika, Werkstudentenstellen und interessante
          technische Projekte.
        </p>

        <a
          class="button button-primary"
          href="mailto:YOUR-EMAIL@example.com"
        >
          E-Mail senden
        </a>
      </section>
    </main>

    <footer>
      <div class="container">
        © {new Date().getFullYear()} Raphael Erwig
      </div>
    </footer>
  </body>
</html>