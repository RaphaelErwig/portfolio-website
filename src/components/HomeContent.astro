---
interface Project {
  number: string;
  category: string;
  title: string;
  description: string;
  highlights: string[];
  href: string;
  duration: string;
  status: string;
  image?: string;
  imageAlt?: string;
}

interface Strength {
  title: string;
  text: string;
}

interface Experience {
  role: string;
  company: string;
  area: string;
  period: string;
  text: string;
  highlights: string[];
  tools: string[];
}

interface SkillGroup {
  title: string;
  skills: string[];
}

interface Props {
  projects: Project[];
  strengths: Strength[];
  skillGroups: SkillGroup[];
  experience: Experience[];
  content: any;
}

const { projects, strengths, skillGroups, experience, content } = Astro.props;
---

<main id="main-content">
  <section class="hero container">
    <div class="hero-content">
      <p class="eyebrow">{content.hero.eyebrow}</p>
      <h1>
        {content.hero.title}
        <span class="highlight">{content.hero.highlight}</span>
      </h1>
      <p class="intro">{content.hero.intro}</p>
      <div class="buttons">
        <a class="button button-primary" href="#projects">{content.hero.primary}</a>
        <a class="button button-secondary" href="#experience">{content.hero.secondary}</a>
      </div>
    </div>
  </section>

  <section id="projects" class="container">
    <div class="section-heading">
      <div>
        <p class="section-kicker">{content.projects.kicker}</p>
        <h2>{content.projects.title}</h2>
      </div>
      <p>{content.projects.lead}</p>
    </div>
    <div class="project-grid">
      {projects.map((project) => (
        <article>
          <a class="project-card" href={project.href}>
            {project.image && (
              <figure class="project-media">
                <img src={project.image} alt={project.imageAlt ?? ''} loading="lazy" />
              </figure>
            )}
            <div class="project-content">
              <div class="project-top">
                <span class="project-number">{project.number}</span>
                <span class="project-category">{project.category}</span>
              </div>
              <div class="project-meta">
                <span>{project.duration}</span>
                <span>{project.status}</span>
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul class="highlight-list">
                {project.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
              <span class="project-link">{content.projects.linkLabel}<span aria-hidden="true"> →</span></span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section id="experience" class="container">
    <div class="section-heading">
      <div>
        <p class="section-kicker">{content.experience.kicker}</p>
        <h2>{content.experience.title}</h2>
      </div>
      <p>{content.experience.lead}</p>
    </div>
    <div class="experience-list">
      {experience.map((item) => (
        <article class="experience-card">
          <div class="experience-summary">
            <p class="experience-period">{item.period}</p>
            <h3>{item.role}</h3>
            <p>{item.area}</p>
          </div>
          <div class="experience-details">
            <div class="experience-company">{item.company}</div>
            <p>{item.text}</p>
            <ul class="experience-highlights">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
            <div class="tool-list" aria-label={content.experience.toolsLabel}>
              {item.tools.map((tool) => <span>{tool}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="about" class="container">
    <div class="section-heading">
      <div>
        <p class="section-kicker">{content.about.kicker}</p>
        <h2>{content.about.title}</h2>
      </div>
      <p>{content.about.lead}</p>
    </div>
    <div class="about-grid">
      <div>
        {content.about.paragraphs.map((paragraph: string) => <p class="about-text">{paragraph}</p>)}
      </div>
      <aside class="principles-card">
        <p class="principles-title">{content.about.principlesTitle}</p>
        <div class="principles-list">
          {strengths.map((strength) => (
            <div>
              <h3>{strength.title}</h3>
              <p>{strength.text}</p>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section id="skills" class="container">
    <div class="section-heading">
      <div>
        <p class="section-kicker">{content.skills.kicker}</p>
        <h2>{content.skills.title}</h2>
      </div>
      <p>{content.skills.lead}</p>
    </div>
    <div class="skill-groups">
      {skillGroups.map((group) => (
        <article class="skill-group">
          <h3>{group.title}</h3>
          <div class="skills">
            {group.skills.map((skill) => <span class="skill">{skill}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="contact" class="contact container">
    <p class="eyebrow">{content.contact.eyebrow}</p>
    <h2>{content.contact.title}</h2>
    <p>{content.contact.text}</p>
    <div class="contact-actions">
      <a class="button button-primary" href="mailto:Raphael.Erwig@icloud.com">{content.contact.button}</a>
      <a class="button button-linkedin" href="https://www.linkedin.com/in/raphael-erwig-4557b8263/" target="_blank" rel="noopener noreferrer">{content.contact.linkedin}</a>
    </div>
  </section>
</main>
